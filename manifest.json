{
  "manifest_version": 3,
  "name": "Plain Text Formatter for Frame.io",
  "version": "1.0.0",
  "description": "Adds Bold, Italic, Strikethrough and Underline buttons to Frame.io comments using Unicode characters.",
  "author": "Becky Isjwara",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://next.frame.io/*",
        "https://app.frame.io/*",
        "https://*.frame.io/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
